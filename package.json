{
  "name": "ai-influencer-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "sh scripts/pre-build.sh",
    "generate-env": "node scripts/generate-env.js",
    "dev": "npm run generate-env development && vite dev",
    "build": "npm run generate-env && vite build",
    "build:dev": "npm run generate-env development && vite build --mode development",
    "build:uat": "npm run generate-env uat && vite build --mode uat",
    "build:prod": "npm run generate-env production && vite build --mode production",
    "preview": "vite preview",
    "preview:uat": "npm run generate-env uat && vite preview --mode uat",
    "preview:prod": "npm run generate-env production && vite preview --mode production",
    "start": "node build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "",
    "lint:fix": "prettier --write . && eslint . --fix",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "5.5.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.3",
    "@types/node": "^20",
    "dotenv": "^17.2.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.54.1",
    "svelte-check": "^4.3.5",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.46.0",
    "firebase": "^12.8.0"
  }
}
